{
  "http": {
    "enableHttp": true,
    "ip": "0.0.0.0",
    "port": 8081
  },
  "mqttBroker": {
    "enableMqttPush": true,
    "ip": "127.0.0.1",
    "port": 1883,
    "clientId": "OcrServer-001",
    "username": "",
    "password": "",
    "reconnect": {
      "initialDelaySeconds": 3,
      "maxDelaySeconds": 60,
      "maxRetries": 0
    }
  },
  "devices": [
    {
      "deviceCode": "DEVICE-001",
      "captureScreenUrl": "http://192.168.8.128:2333",
      "timeoutSeconds": 10,
      "captureFrequency": 3,
      "defaultExtendPayload": {
        "DEVICECODE": "110001"
      },
      "topics": [
        {
          "name": "gateway/collection/110001",
          "extendPayload": {
            "GroupCode": "collection1"
          }
        },
        {
          "name": "gateway/alarm/110001",
          "extendPayload": {
            "GroupCode": "alarm1"
          }
        }
      ]
    }
  ],
  "csvRecord": false,
  "serilog": {
    "minimumLevel": "Information",
    "console": {
      "minimumLevel": "Debug"
    },
    "file": {
      "path": "logs/ocrserver-.log",
      "rollingInterval": "Day",
      "minimumLevel": "Warning",
      "retainedFileCountLimit": 7
    }
  }
}
