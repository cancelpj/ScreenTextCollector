{
  "CsvRecord": false, // 是否记录为CSV文件
  "Http": {
    "EnableHttp": true, // 是否启用HTTP服务
    "Ip": "127.0.0.1", // 填真实IP
    "Port": 8004
  },
  "MqttBroker": {
    "EnableMqttPush": true, // 是否启用MQTT推送
    "CaptureFrequency": 2, // 采集频率，单位：秒
    "Ip": "127.0.0.1", // MQTT服务器IP地址
    "Port": 1883, // MQTT服务器端口
    "ClientId": "MyClientId", // MQTT客户端ID
    "Username": "admin", // MQTT用户名
    "Password": "password", // MQTT密码
    "DefaultTopic": {
      "Name": "screen/collection/110001",
      "ExtendPayload": {
        "CLIENT": "MyClientId", // 采集客户端ID
        "DEVICECODE": "110001", // 设备名称
        "EQUIPMENT": "110001",
        "GroupCode": "collection1"
      }
    },
    "Topics": [ // 多Topic配置
      {
        "Name": "screen/collection/110001",
        "ExtendPayload": {
          "GroupCode": "collection1"
        }
      },
      {
        "Name": "screen/alarm/110001",
        "ExtendPayload": {
          "GroupCode": "alarm1"
        }
      }
    ]
  }
}
